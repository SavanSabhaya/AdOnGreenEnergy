{
  "name": "adongreenenergy",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "build": "npx @tailwindcss/cli -i app/globals.css -o public/tailwind.css && next build",
    "dev": "npx @tailwindcss/cli -i app/globals.css -o public/tailwind.css --watch & next dev",
    "start": "next start",
    "lint": "eslint",
    "preview": "opennextjs-cloudflare build && opennextjs-cloudflare preview",
    "deploy": "npx @tailwindcss/cli -i app/globals.css -o public/tailwind.css && opennextjs-cloudflare build && opennextjs-cloudflare deploy",
    "upload": "npx @tailwindcss/cli -i app/globals.css -o public/tailwind.css && opennextjs-cloudflare build && opennextjs-cloudflare upload",
    "cf-typegen": "wrangler types --env-interface CloudflareEnv cloudflare-env.d.ts"
  },
  "dependencies": {
    "@opennextjs/cloudflare": "^1.20.2",
    "@react-three/drei": "^10.7.7",
    "@react-three/fiber": "^9.6.1",
    "@svg-maps/india": "^2.0.0",
    "@types/three": "^0.185.0",
    "clsx": "^2.1.1",
    "framer-motion": "^12.42.2",
    "lucide-react": "^1.23.0",
    "next": "16.2.11",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "three": "^0.185.1"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.11",
    "tailwindcss": "^4",
    "typescript": "^5",
    "wrangler": "^4.113.0"
  }
}
